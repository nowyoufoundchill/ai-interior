# P0.0 test isolation (docs/P0_P1_EXECUTION_PLAN_2026-07-10.md): a SEPARATE
# Supabase project so automated test runs never touch production data. Copy
# this file to .env.test and fill in the second project's credentials.
#
# FAIL CLOSED: since P0.0 there is NO fallback to .env.local. Every
# mutation-capable script/suite (seed:test, teardown:test, suite:*) refuses
# to run when .env.test is missing or resolves to the same Supabase project
# as .env.local. Start the app under test with `npm run dev:test` so the
# server itself is bound to this project; suites verify that through
# GET /api/debug/env-fingerprint before their first write.
#
# Provisioning steps: docs/TEST_PROJECT_SETUP.md

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI_MODE=mock is the default assumption for all test loops (instant,
# schema-valid canned output, no provider spend). Suite 3 (Live API smoke)
# explicitly overrides this to "live" for its one paid pass per cycle:
#   AI_MODE=live npm run dev:test
AI_MODE=mock

# Same three provider keys as .env.local — only used when AI_MODE=live
# (Suite 3). Safe to leave blank if this test project never runs live.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
TAVILY_API_KEY=
