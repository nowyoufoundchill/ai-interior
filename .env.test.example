# PRD v3 test harness (§3): a SEPARATE Supabase project so automated test
# runs never touch production data. Copy this file to .env.test and fill in
# a second Supabase project's credentials once one is provisioned.
#
# Until this file exists, test scripts fall back to .env.local (the real
# project) with a loud warning, and rely on strict test_run_id tagging +
# teardown + the residue check instead of true environment isolation.
# See PROJECT_BRAIN.md "Known Gaps Against PRD v3" for the current status.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI_MODE=mock is the default assumption for all test loops (instant,
# schema-valid canned output, no provider spend). Suite 3 (Live API smoke)
# explicitly overrides this to "live" for its one paid pass per cycle.
AI_MODE=mock

# Same three provider keys as .env.local — only used when AI_MODE=live
# (Suite 3). Safe to leave blank if this test project never runs live.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
TAVILY_API_KEY=
