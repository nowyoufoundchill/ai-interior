# Optional ISOLATED test mode. Copy this file to .env.test and fill in a
# separate Supabase project's credentials. When present, a valid isolated
# .env.test always takes precedence over the owner-acknowledged production
# mode recorded in test-isolation.config.json.
#
# FAIL CLOSED: an invalid .env.test never falls back silently. Start the app
# under test with `npm.cmd run dev:test` so the server is bound to this project;
# suites verify that through GET /api/debug/env-fingerprint before writing.
#
# Current policy and provisioning steps: docs/OPERATIONS.md

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI_MODE=mock is the default assumption for all test loops (instant,
# schema-valid canned output, no provider spend). Suite 3 (Live API smoke)
# explicitly overrides this to "live" for its one paid pass per cycle:
#   $env:AI_MODE="live"
#   npm.cmd run dev:test
AI_MODE=mock

# Same three provider keys as .env.local — only used when AI_MODE=live
# (Suite 3). Safe to leave blank if this test project never runs live.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
TAVILY_API_KEY=
